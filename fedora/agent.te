policy_module(agent, 1.0)

gen_require(`
    role staff_r;
    attribute file_type;
    type staff_sudo_t;
    type su_exec_t;
    class dir { read search getattr };
    class file { getattr read open ioctl lock execute };
    class fifo_file { read write };
    class sock_file { write getattr };
    class process { getattr setsched };
')

type agent_t;
type agent_exec_t;

role staff_r types agent_t;

domain_type(agent_t)
domain_entry_file(agent_t, agent_exec_t)

# Allow sudo transition
allow staff_sudo_t agent_t:process transition;
allow staff_sudo_t agent_t:key create;

########################################
# Booleans
#

gen_bool(agent_manage_systemd, false)

tunable_policy(`agent_manage_systemd',`
    systemd_exec_systemctl(agent_t)
    init_read_state(agent_t)
    init_stream_connectto(agent_t)
    init_write_pid_socket(agent_t)
    kernel_read_fs_sysctls(agent_t)
    term_search_ptys(agent_t)
    userdom_use_user_ptys(agent_t)
')

########################################
#
# Read permissions (diagnostics)
#
domain_use_interactive_fds(agent_t)
files_read_etc_files(agent_t)
miscfiles_read_localization(agent_t)

kernel_read_system_state(agent_t)
sysnet_read_config(agent_t)
dev_read_sysfs(agent_t)

logging_read_all_logs(agent_t)
logging_send_syslog_msg(agent_t)

# Basic execution needed for sudo + common tools
corecmd_exec_bin(agent_t)
corecmd_mmap_bin_files(agent_t)
corecmd_shell_entry_type(agent_t)
userdom_use_inherited_user_ptys(agent_t)

allow agent_t self:capability { dac_read_search sys_ptrace };
allow agent_t self:process { getattr getsched getpgid };

selinux_get_enforce_mode(agent_t)
seutil_search_default_contexts(agent_t)

# Needed for sudo and user switching
allow agent_t su_exec_t:file execute;

# Self permissions that appeared in denials
allow agent_t self:netlink_audit_socket create;
allow agent_t self:process setpgid;

########################################
#
# Trying Catch-all
#

# Broad read access to most files and directories on the system
allow agent_t file_type : dir { getattr read open search };
allow agent_t file_type : file { getattr read open };
allow agent_t file_type : lnk_file { getattr read };

# Read access to other domains' directories
allow agent_t domain : dir { read search getattr };

########################################
#
# Don't log denials for writing
#
dontaudit agent_t file_type : { file dir lnk_file } { write create append unlink rename setattr };
dontaudit agent_t self:capability dac_override;
