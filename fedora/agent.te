policy_module(agent, 1.0)

gen_require(`
    role staff_r;
    type var_t;
    type etc_t;
    attribute file_type;
    type var_log_t;
    type staff_sudo_t;
    type systemd_systemctl_exec_t;

    # Added for the recent denials
    type passwd_file_t;
    type su_exec_t;
    type systemd_userdbd_runtime_t;
    type user_home_dir_t;
    type user_home_t;
    type audio_home_t;
')

type agent_t;
type agent_exec_t;

role staff_r types agent_t;

domain_type(agent_t)
domain_entry_file(agent_t, agent_exec_t)

# Allow sudo transition
allow staff_sudo_t agent_t:process transition;
allow staff_sudo_t agent_t:key create;

########################################
# Booleans
#

gen_bool(agent_manage_systemd, false)

tunable_policy(`agent_manage_systemd',`
    systemd_exec_systemctl(agent_t)
    init_read_state(agent_t)
    init_stream_connectto(agent_t)
    init_write_pid_socket(agent_t)
    kernel_read_fs_sysctls(agent_t)
    term_search_ptys(agent_t)
    userdom_use_user_ptys(agent_t)
')

########################################
#
# Read permissions (diagnostics)
#
domain_use_interactive_fds(agent_t)
files_read_etc_files(agent_t)
miscfiles_read_localization(agent_t)

kernel_read_system_state(agent_t)
sysnet_read_config(agent_t)
dev_read_sysfs(agent_t)

logging_read_all_logs(agent_t)
logging_send_syslog_msg(agent_t)

# Basic execution needed for sudo + common tools
corecmd_exec_bin(agent_t)
corecmd_mmap_bin_files(agent_t)
corecmd_shell_entry_type(agent_t)
userdom_use_inherited_user_ptys(agent_t)

allow agent_t self:capability { dac_read_search sys_ptrace sys_admin net_admin };
allow agent_t self:process { getattr getsched getpgid };

selinux_get_enforce_mode(agent_t)
seutil_search_default_contexts(agent_t)

# Read /etc/passwd and related files
allow agent_t passwd_file_t:file read;

# Needed for sudo and user switching
allow agent_t su_exec_t:file execute;

# systemd user database lookup (very common on modern Fedora)
allow agent_t systemd_userdbd_runtime_t:dir read;

# Basic access to other users' home directories (getattr + search)
allow agent_t user_home_dir_t:dir { getattr search read open };

# Self permissions that appeared in denials
allow agent_t self:netlink_audit_socket create;
allow agent_t self:process setpgid;

# Allow getattr on files and directories inside other users' homes (needed for ls -l)
allow agent_t user_home_t:dir getattr;
allow agent_t user_home_t:file { getattr read open };

# Special content directories (Desktop, Downloads, etc. often have their own types)
allow agent_t audio_home_t:dir getattr;

# Update passwd access (open is now needed in addition to read)
allow agent_t passwd_file_t:file { read open };

# systemd user database support (for sudo -u and user lookups)
allow agent_t systemd_userdbd_runtime_t:lnk_file read;
allow agent_t systemd_userdbd_runtime_t:sock_file write;

########################################
#
# Don't log denials for writing
#
dontaudit agent_t file_type:dir { write create unlink };
dontaudit agent_t file_type:file { write create setattr unlink append };
dontaudit agent_t etc_t:file { write create setattr };
dontaudit agent_t var_t:dir { write create };
dontaudit agent_t var_log_t:file { write append };
dontaudit agent_t self:capability dac_override;
dontaudit agent_t file_type:dir { write create unlink };
dontaudit agent_t file_type:file { write create setattr unlink append };
